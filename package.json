{
  "name": "@salutejs/sdds-mcp",
  "version": "0.1.1",
  "description": "MCP server for SDDS",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "sdds-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "inspect:dev": "npx @modelcontextprotocol/inspector npx tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "plasma",
    "design-system"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/salute-developers/plasma-mcp-server"
  },
  "bugs": {
    "url": "https://github.com/salute-developers/plasma-mcp-server/issues"
  },
  "homepage": "https://github.com/salute-developers/plasma-mcp-server",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.16.8",
    "@types/node": "^20.17.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
