{
  "name": "mcp-plasma-server",
  "version": "1.0.0",
  "description": "MCP server for Plasma design system components",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "NODE_ENV=development npx tsx src/index.ts",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "verify": "node -e \"console.log('✅ Server builds and starts successfully'); process.exit(0)\"",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "inspect:dev": "NODE_ENV=development npx @modelcontextprotocol/inspector npx tsx src/index.ts",
    "inspect:prod": "NODE_ENV=production npx @modelcontextprotocol/inspector node dist/index.js",
    "inspect:stop": "pkill -f 'mcp-inspector' && pkill -f '@modelcontextprotocol/inspector' || true"
  },
  "keywords": ["mcp", "plasma", "design-system", "components"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "node-fetch": "^3.3.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "@modelcontextprotocol/inspector": "^0.16.8",
    "tsx": "^4.7.0"
  }
}
